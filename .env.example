# ─── Canvas ───────────────────────────────────────────────────────────────────
# Canvas does NOT need any credentials here for student use.
# Students connect using a Personal Access Token generated from their Canvas
# profile settings page. No admin access required.

# ─── Google Classroom (optional) ─────────────────────────────────────────────
# Only needed if you want to connect Google Classroom.
# Create a free OAuth app at console.cloud.google.com → Credentials → Desktop app.
# Redirect URI: student-hub://oauth/google-classroom/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft Teams EDU (optional) ──────────────────────────────────────────
# Only needed if you want to connect Teams.
# Register at portal.azure.com → App registrations.
# Redirect URI: student-hub://oauth/microsoft-teams/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common

# ─── Development ──────────────────────────────────────────────────────────────
# Set to true to open DevTools automatically when the app starts
DEVTOOLS_OPEN=false
